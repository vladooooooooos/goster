{
  "app": {
    "name": "Indexator",
    "version": "0.1.0"
  },
  "ui": {
    "window_width": 1100,
    "window_height": 720
  },
  "embedding": {
    "model_name": "BAAI/bge-m3",
    "device": "auto",
    "batch_size": 8,
    "normalize_embeddings": true
  },
  "storage": {
    "provider": "qdrant",
    "collection_name": "gost_blocks",
    "url": "http://127.0.0.1:6333",
    "host": "127.0.0.1",
    "port": 6333,
    "https": false,
    "timeout_seconds": 5.0,
    "api_key": "",
    "shared_data_path": "../shared/data",
    "distance_metric": "Cosine"
  }
}
