GOST_CHAT_APP_NAME=GOST Chat
GOST_CHAT_LLM_PROVIDER=polza
GOST_CHAT_LLM_BASE_URL=https://polza.ai/api/v1
GOST_CHAT_LLM_MODEL=google/gemma-4-31b-it
GOST_CHAT_LLM_TEMPERATURE=0.2
GOST_CHAT_LLM_MAX_TOKENS=5000
GOST_CHAT_LLM_REQUEST_TIMEOUT_SECONDS=120
GOST_CHAT_LLM_API_KEY_ENV_VAR=POLZA_API_KEY
# Set POLZA_API_KEY in your shell or secret manager. Do not commit real API keys.
GOST_CHAT_INDEXER_OUTPUT_DIR=data
GOST_CHAT_LOG_LEVEL=INFO
GOST_CHAT_RETRIEVAL_BACKEND=auto
GOST_CHAT_QDRANT_URL=http://127.0.0.1:6333
GOST_CHAT_QDRANT_HOST=127.0.0.1
GOST_CHAT_QDRANT_PORT=6333
GOST_CHAT_QDRANT_HTTPS=false
GOST_CHAT_QDRANT_TIMEOUT_SECONDS=5.0
GOST_CHAT_QDRANT_API_KEY=
GOST_CHAT_QDRANT_COLLECTION_NAME=gost_blocks
GOST_CHAT_EMBEDDING_MODEL_NAME=BAAI/bge-m3
GOST_CHAT_EMBEDDING_DEVICE=auto
GOST_CHAT_EMBEDDING_BATCH_SIZE=4
GOST_CHAT_EMBEDDING_NORMALIZE_EMBEDDINGS=true
GOST_CHAT_RERANKER_ENABLED=true
GOST_CHAT_RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
GOST_CHAT_RERANKER_DEVICE=auto
GOST_CHAT_RERANKER_BATCH_SIZE=2
GOST_CHAT_RERANKER_MAX_LENGTH=512
GOST_CHAT_RERANKER_TOP_K=40
GOST_CHAT_RERANKER_TOP_N=12
GOST_CHAT_RERANKER_USE_FP16_IF_AVAILABLE=true
GOST_CHAT_CONTEXT_MIN_BLOCKS=2
GOST_CHAT_CONTEXT_SOFT_TARGET_BLOCKS=5
GOST_CHAT_CONTEXT_SIMPLE_TARGET_BLOCKS=5
GOST_CHAT_CONTEXT_MAX_BLOCKS=12
GOST_CHAT_CONTEXT_MAX_CHARS=18000
GOST_CHAT_CONTEXT_ADAPTIVE_SCORE_THRESHOLD=0.12
GOST_CHAT_VISUAL_ENABLE_DECISION=true
GOST_CHAT_VISUAL_CROPS_DIR=data/crops
GOST_CHAT_VISUAL_CROP_DPI=160
GOST_CHAT_VISUAL_MAX_CROPS_PER_ANSWER=4
GOST_CHAT_VISUAL_VISION_ENABLED=true
GOST_CHAT_VISUAL_PAGE_RENDER_DPI=120
GOST_CHAT_VISUAL_CANDIDATE_LIMIT=8
